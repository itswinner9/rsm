# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (resume optimization)
OPENROUTER_API_KEY=

# Polar — Organization Access Token (Dashboard → Settings → Developers). Never commit real values.
POLAR_ACCESS_TOKEN=
# sandbox (default) or production
POLAR_SERVER=sandbox

# Polar product IDs (Dashboard → Products → copy product UUID for each plan)
POLAR_PRODUCT_ID_PRO=
POLAR_PRODUCT_ID_RECRUITING=

# Webhook signing secret (Dashboard → Settings → Webhooks)
POLAR_WEBHOOK_SECRET=
