# App — use your production origin on Vercel (no trailing slash), e.g. https://your-app.vercel.app
# Needed for Open Graph, Polar checkout, and consistent server-side URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — required in all Vercel environments that run the app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Production checklist (see docs/production-auth.md):
# - Supabase → Authentication → URL Configuration: Site URL = https://your-domain.com
# - Redirect URLs must include https://your-domain.com/auth/callback (and preview URLs if used)
# - Google OAuth redirect URI in Google Cloud: https://<project-ref>.supabase.co/auth/v1/callback

# OpenRouter (resume optimization)
OPENROUTER_API_KEY=

# Polar — Organization Access Token (Dashboard → Settings → Developers). Never commit real values.
POLAR_ACCESS_TOKEN=
# sandbox (default) or production
POLAR_SERVER=sandbox

# Polar product IDs (Dashboard → Products → copy product UUID for each plan)
POLAR_PRODUCT_ID_PRO=
POLAR_PRODUCT_ID_RECRUITING=

# Webhook signing secret (Dashboard → Settings → Webhooks)
POLAR_WEBHOOK_SECRET=
