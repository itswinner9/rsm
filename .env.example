# =============================================================================
# Environment variables — full reference: docs/environment-variables.md
# Copy this file to .env.local and fill in values. Do not commit .env.local.
# =============================================================================

# --- App URL (public) ---
# Production: https://your-domain.com (no trailing slash). Never use localhost on Vercel Production.
# Used for: Open Graph, Stripe checkout redirects, OpenRouter Referer, auth redirects, metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3002

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; bypasses RLS for webhooks/sync. Never expose to the browser or commit.
SUPABASE_SERVICE_ROLE_KEY=

# Auth URLs checklist: docs/production-auth.md
# - Site URL and Redirect URLs in Supabase must include https://your-domain.com/auth/callback
# - Google OAuth: Authorized redirect URI = https://<project-ref>.supabase.co/auth/v1/callback

# --- OpenRouter (server-only; required for /api/optimize-resume) ---
OPENROUTER_API_KEY=

# --- Stripe (Dashboard → Developers → API keys & Webhooks) ---
# sk_live_... or sk_test_... — server-only; never commit real keys; paste from Dashboard into .env.local only.
STRIPE_SECRET_KEY=
# Webhook signing secret for POST /api/stripe/webhook (from Dashboard → Webhooks → Signing secret)
STRIPE_WEBHOOK_SECRET=

# Optional: Stripe Product ID — if set, the app picks monthly/yearly Price IDs from this product when
# STRIPE_PRICE_*_CAD is blank or wrong (9.99, sub_...). You still need monthly + yearly recurring prices on the product.
# STRIPE_SUBSCRIPTION_PRODUCT_ID=prod_UGomAeE8XjMyoW
# Stripe Price IDs in CAD — must start with price_ (Product catalog → product → Pricing).
# See docs/stripe-billing.md → "Creating Prices in the Dashboard" and docs/environment-variables.md.
# Do NOT use: subscription (sub_...), product (prod_...), customer (cus_...), or dollar amounts (9.99, 999).
# Test keys → Test mode Price IDs; Live keys → Live mode Price IDs. After changing env on Vercel, redeploy.
# If STRIPE_PRICE_* is mistakenly set to sub_..., the app falls back to inline pricing (server log warning).
# If you leave MONTHLY/YEARLY empty, Checkout uses inline amounts (defaults: $9.99/mo and $99.99/yr in cents below).
STRIPE_PRICE_MONTHLY_CAD=price_1TIeK9CcyXH3r2Y4OD8kMPZe
STRIPE_PRICE_YEARLY_CAD=price_1TIeLNCcyXH3r2Y49kkLt5P5
# Optional: monthly only — open this Stripe Payment Link instead of POST /api/stripe/checkout for `plan=month`.
# Yearly still uses API Checkout. Use test vs live links to match your STRIPE_SECRET_KEY mode.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_MONTHLY=https://buy.stripe.com/28E3cu9oZ4E79zG40t53O01
# Optional overrides when Price IDs are unset (integer cents, CAD)
# STRIPE_PRICE_MONTHLY_CENTS=999
# STRIPE_PRICE_YEARLY_CENTS=9999
# Note: Publishable key pk_... is not required unless you add client-side Stripe.js.
