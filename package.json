{
  "name": "resumify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:free": "bash -c 'pids=$(lsof -t -iTCP:3002 -sTCP:LISTEN 2>/dev/null); [ -n \"$pids\" ] && kill $pids && echo \"Freed port 3002\" || echo \"Nothing was listening on 3002\"'",
    "dev:clean": "rm -rf .next node_modules/.cache && next dev -p 3002",
    "clean": "rm -rf .next node_modules/.cache",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "stripe:listen": "stripe listen --forward-to localhost:3002/api/stripe/webhook"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@fingerprintjs/fingerprintjs": "^4.6.2",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@react-pdf/renderer": "^4.3.2",
    "@remixicon/react": "^4.9.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "disposable-email-domains": "^1.0.62",
    "docx": "^9.6.1",
    "framer-motion": "^11.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.344.0",
    "mammoth": "^1.7.0",
    "next": "14.2.35",
    "openai": "^6.33.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "postcss": "^8",
    "react": "^18",
    "react-dom": "^18",
    "react-dropzone": "^14.2.3",
    "react-use-measure": "^2.1.7",
    "stripe": "^17.7.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "unpdf": "^1.4.0",
    "zod": "^4.3.6"
  }
}
